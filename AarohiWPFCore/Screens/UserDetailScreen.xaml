<Window x:Class="AarohiWPFCore.Screens.UserDetailScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AarohiWPFCore.Screens"
        mc:Ignorable="d"
        Title="UserDetailScreen" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="0,0,-20,10">
        <Border Width="700"
                Height="400"
                BorderBrush="DarkGoldenrod"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">
            <StackPanel>
                <TextBlock Text="User Management System"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0,0,0" />

                <TextBlock Text="User Dashboard"
                           FontSize="15"
                           FontWeight="DemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,5,0,0" />

                <TextBlock Text="Users"
                           FontSize="12"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="10,5,0,0" />

                <DataGrid x:Name="userData"
                          Height="210"
                          Width="650"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False" />

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnShow"
                            Content="Show"
                            Width="60"
                            Height="20"
                            Margin="490,20,0,0"
                            HorizontalAlignment="Left"
                            Click="btnShow_Click" />

                    <Button x:Name="btnClose"
                            Content="Close"
                            Width="60"
                            Height="20"
                            Margin="30,20,0,0"
                            HorizontalAlignment="Left"
                            Click="btnClose_Click" />

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>

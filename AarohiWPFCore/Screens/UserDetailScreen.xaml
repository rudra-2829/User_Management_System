<Window x:Class="Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Responsive Layout"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- ================= ROWS ================= -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <!-- Top Navbar -->
            <RowDefinition Height="*" />
            <!-- Main Content -->
            <RowDefinition Height="40" />
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ================= TOP NAVBAR ================= -->
        <Border Grid.Row="0"
                Background="#2C3E50">

            <DockPanel Margin="15,0">

                <TextBlock Text="User Management System"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Home"
                            Width="80"
                            Height="30"
                            Margin="5" />

                    <Button Content="Profile"
                            Width="80"
                            Height="30"
                            Margin="5" />

                    <Button Content="Logout"
                            Width="80"
                            Height="30"
                            Margin="5" />

                </StackPanel>

            </DockPanel>

        </Border>

        <!-- ================= MAIN AREA ================= -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>

                <!-- Left Menu -->
                <ColumnDefinition Width="180" />

                <!-- Center -->
                <ColumnDefinition Width="*" />

                <!-- Right Menu -->
                <ColumnDefinition Width="180" />

            </Grid.ColumnDefinitions>

            <!-- ================= LEFT MENU ================= -->

            <Border Grid.Column="0"
                    Background="#ECF0F1"
                    BorderBrush="Gray"
                    BorderThickness="0,0,1,0">

                <StackPanel Margin="10">

                    <TextBlock Text="Navigation"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,15" />

                    <Button Content="Dashboard"
                            Height="35"
                            Margin="0,5" />

                    <Button Content="Users"
                            Height="35"
                            Margin="0,5" />

                    <Button Content="Departments"
                            Height="35"
                            Margin="0,5" />

                    <Button Content="Reports"
                            Height="35"
                            Margin="0,5" />

                </StackPanel>

            </Border>

            <!-- ================= CENTER CONTENT ================= -->

            <Border Grid.Column="1"
                    Margin="15"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Users"
                               FontSize="18"
                               FontWeight="Bold" />

                    <DataGrid Grid.Row="2"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />

                </Grid>

            </Border>

            <!-- ================= RIGHT MENU ================= -->

            <Border Grid.Column="2"
                    Background="#ECF0F1"
                    BorderBrush="Gray"
                    BorderThickness="1,0,0,0">

                <StackPanel Margin="10">

                    <TextBlock Text="Quick Actions"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,15" />

                    <Button Content="Add User"
                            Height="35"
                            Margin="0,5" />

                    <Button Content="Edit User"
                            Height="35"
                            Margin="0,5" />

                    <Button Content="Delete User"
                            Height="35"
                            Margin="0,5" />

                </StackPanel>

            </Border>

        </Grid>

        <!-- ================= FOOTER ================= -->

        <Border Grid.Row="2"
                Background="#2C3E50">

            <TextBlock Text="© 2026 User Management System"
                       Foreground="White"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />

        </Border>

    </Grid>

</Window>
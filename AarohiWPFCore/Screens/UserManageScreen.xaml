<Window x:Class="AarohiWPFCore.Screens.UserManageScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AarohiWPFCore.Screens"
        mc:Ignorable="d"
        Title="UserManageScreen"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Border Width="700"
                Height="430"
                BorderBrush="DarkGoldenrod"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">
            <StackPanel>
                <TextBlock Text="User Management System"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0,0,0" />

                <TextBlock Text="Manage User"
                           FontSize="15"
                           FontWeight="DemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,5,0,0" />

                <TextBlock Text="Users"
                           FontSize="12"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="10,5,0,0" />

                <DataGrid x:Name="userData"
                          Height="210"
                          Width="650"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False" />

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnAdd"
                            Content="Add"
                            Width="60"
                            Height="20"
                            Margin="20,20,0,0"
                            HorizontalAlignment="Left"
                            Click="btnAdd_Click" />

                    <Button x:Name="btnEdit"
                            Content="Edit"
                            Width="60"
                            Height="20"
                            Margin="20,20,0,0"
                            HorizontalAlignment="Left"
                            Click="btnEdit_Click" />

                    <Button x:Name="btnDelete"
                            Content="Delete"
                            Width="60"
                            Height="20"
                            Margin="20,20,0,0"
                            HorizontalAlignment="Left"
                            Click="btnDelete_Click" />

                    <Button x:Name="btnBack"
                            Content="Back"
                            Width="60"
                            Height="20"
                            Margin="330,20,0,0"
                            HorizontalAlignment="Left"
                            Click="btnBack_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>

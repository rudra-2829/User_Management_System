<Window x:Class="AarohiWPFCore.Screens.UserLoginScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AarohiWPFCore.Screens"
        mc:Ignorable="d"
        Title="UserLoginScreen" Height="450" Width="800"
        WindowState="Minimized"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Border Width="600"
                Height="400"
                BorderBrush="DarkGray"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">
            <StackPanel>
                <TextBlock Text="User Management System"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0" />
                <TextBlock Text="User Login"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top" 
                           Margin="0,30,0,0"/>
                <TextBlock Text="Username:"
                           Margin="200,50,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top" />
                <TextBox x:Name="txtUserName"
                         Width="200"
                         Height="20"
                         Margin="200,0,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"/>
                <TextBlock Text="Password:"
                           Margin="200,20,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top" />
                <PasswordBox x:Name="txtPassword"
                             Width="200"
                             Height="20"
                             Margin="200,0,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top" />
                <Button Content="Login"
                        Width="80"
                        Height="30"
                        Margin="0,50,0,0"
                        Click="btnLogin_Click"
                        RenderTransformOrigin="0.476,0.346" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

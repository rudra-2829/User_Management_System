<Window x:Class="AarohiWPFCore.Screens.AddEditScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AarohiWPFCore.Screens"
        mc:Ignorable="d"
        Title="AddEditScreen" Height="450" Width="300"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Border Width="250"
                Height="400"
                BorderBrush="DarkGray"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="User Management"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0" />

                <TextBlock Text="User ID:"
                           Margin="10,20,0,0"
                           HorizontalAlignment="Left" />
                <TextBox x:Name="txtUserId"
                         Width="200"
                         Height="20"
                         Margin="10,0,0,0"
                         HorizontalAlignment="Left"
                         IsReadOnly="True" />

                <TextBlock Text="User Name:"
                           Margin="10,10,0,0"
                           HorizontalAlignment="Left" />
                <TextBox x:Name="txtUserName"
                         Width="200"
                         Height="20"
                         Margin="10,0,0,0"
                         HorizontalAlignment="Left"
                         IsReadOnly="False" />

                <TextBlock Text="Password:"
                           Margin="10,10,0,0"
                           HorizontalAlignment="Left" />
                <PasswordBox x:Name="txtPassword"
                         Width="200"
                         Height="20"
                         Margin="10,0,0,0"
                         HorizontalAlignment="Left"/>

                <TextBlock Text="First Name:"
                           Margin="10,10,0,0"
                           HorizontalAlignment="Left" />
                <TextBox x:Name="txtFirstName"
                         Width="200"
                         Height="20"
                         Margin="10,0,0,0"
                         HorizontalAlignment="Left"
                         IsReadOnly="False" />

                <TextBlock Text="Last Name:"
                           Margin="10,10,0,0"
                           HorizontalAlignment="Left" />
                <TextBox x:Name="txtLastName"
                         Width="200"
                         Height="20"
                         Margin="10,0,0,0"
                         HorizontalAlignment="Left"
                         IsReadOnly="False" />

                <TextBlock Text="EmailAddress:"
                           Margin="10,10,0,0"
                           HorizontalAlignment="Left" />
                <TextBox x:Name="txtEmailAddress"
                         Width="200"
                         Height="20"
                         Margin="10,0,0,0"
                         HorizontalAlignment="Left" />
                
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,0">
                    <Button x:Name="btnSave"
                            Content="Save"
                            Width="50"
                            Height="30"
                            Margin="0,20,10,0"
                            Click="btnSave_Click" />
                    <Button x:Name="btnCancel"
                            Content="Cancel"
                            Width="50"
                            Height="30"
                            Margin="50,20,10,0"
                            Click="btnCancel_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>

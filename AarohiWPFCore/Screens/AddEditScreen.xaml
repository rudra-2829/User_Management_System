<Window x:Class="AarohiWPFCore.Screens.AddEditScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AarohiWPFCore.Screens"
        mc:Ignorable="d"
        Title="Add / Edit User"
        Width="600"
        Height="500"
        MinWidth="500"
        MinHeight="450"
        WindowStartupLocation="CenterScreen">

    <Grid Background="White">

        <Border BorderBrush="DarkGray"
                BorderThickness="1"
                Margin="20"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="500">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="User Management"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />

                <!-- Form -->
                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- User ID -->
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="User ID:"
                               VerticalAlignment="Center"
                               Margin="0,5" />

                    <TextBox x:Name="txtUserId"
                             Grid.Row="0"
                             Grid.Column="1"
                             Height="28"
                             Margin="0,5"
                             IsReadOnly="True" />

                    <!-- User Name -->
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="User Name:"
                               VerticalAlignment="Center"
                               Margin="0,5" />

                    <TextBox x:Name="txtUserName"
                             Grid.Row="1"
                             Grid.Column="1"
                             Height="28"
                             Margin="0,5" />

                    <!-- Password -->
                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Password:"
                               VerticalAlignment="Center"
                               Margin="0,5" />

                    <PasswordBox x:Name="txtPassword"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Height="28"
                                 Margin="0,5" />

                    <!-- First Name -->
                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="First Name:"
                               VerticalAlignment="Center"
                               Margin="0,5" />

                    <TextBox x:Name="txtFirstName"
                             Grid.Row="3"
                             Grid.Column="1"
                             Height="28"
                             Margin="0,5" />

                    <!-- Last Name -->
                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Last Name:"
                               VerticalAlignment="Center"
                               Margin="0,5" />

                    <TextBox x:Name="txtLastName"
                             Grid.Row="4"
                             Grid.Column="1"
                             Height="28"
                             Margin="0,5" />

                    <!-- Email -->
                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Text="Email Address:"
                               VerticalAlignment="Center"
                               Margin="0,5" />

                    <TextBox x:Name="txtEmailAddress"
                             Grid.Row="5"
                             Grid.Column="1"
                             Height="28"
                             Margin="0,5" />

                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Row="9"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button x:Name="btnSave"
                            Content="Save"
                            Width="90"
                            Height="35"
                            Margin="0,0,10,0"
                            Click="btnSave_Click" />

                    <Button x:Name="btnCancel"
                            Content="Cancel"
                            Width="90"
                            Height="35"
                            Click="btnCancel_Click" />

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>